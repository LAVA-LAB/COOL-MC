// ===== Reward structures =====

// Shortage: for demand outcome b, shortage = max(0, b - tinv)
// Outdating: for demand outcome b, outdating = max(0, x1 - b)
// Expected values computed as sum over b of p_b * cost_b

// Expected shortage given current total inventory
formula exp_short = p0 * max(0, 0 - tinv) + p1 * max(0, 1 - tinv) + p2 * max(0, 2 - tinv) + p3 * max(0, 3 - tinv) + p4 * max(0, 4 - tinv) + p5 * max(0, 5 - tinv) + p6 * max(0, 6 - tinv) + p7 * max(0, 7 - tinv) + p8 * max(0, 8 - tinv) + p9 * max(0, 9 - tinv) + p10 * max(0, 10 - tinv) + p11 * max(0, 11 - tinv) + p12 * max(0, 12 - tinv) + p13 * max(0, 13 - tinv) + p14 * max(0, 14 - tinv) + p15 * max(0, 15 - tinv) + p16 * max(0, 16 - tinv) + p17 * max(0, 17 - tinv) + p18 * max(0, 18 - tinv) + p19 * max(0, 19 - tinv) + p20 * max(0, 20 - tinv);

// Expected outdating given oldest stock x1
formula exp_outdate = p0 * max(0, x1 - 0) + p1 * max(0, x1 - 1) + p2 * max(0, x1 - 2) + p3 * max(0, x1 - 3) + p4 * max(0, x1 - 4) + p5 * max(0, x1 - 5) + p6 * max(0, x1 - 6) + p7 * max(0, x1 - 7) + p8 * max(0, x1 - 8) + p9 * max(0, x1 - 9) + p10 * max(0, x1 - 10) + p11 * max(0, x1 - 11) + p12 * max(0, x1 - 12) + p13 * max(0, x1 - 13) + p14 * max(0, x1 - 14) + p15 * max(0, x1 - 15) + p16 * max(0, x1 - 16) + p17 * max(0, x1 - 17) + p18 * max(0, x1 - 18) + p19 * max(0, x1 - 19) + p20 * max(0, x1 - 20);

rewards "cost"
  ph=1 : CS * exp_short + CO * exp_outdate;
endrewards



// ===== Labels =====

label "monday"     = d=0;
label "weekend"    = d>=5;
label "empty"      = tinv=0;
label "full"       = tinv=MAXS;
label "safe_stock" = tinv>=5;

// ===== Example properties (save as .pctl) =====
// Rmin=? [ S {"cost"} ]           // min long-run avg cost

//
// Sweep demand rate: prism model.nm props.pctl -const lam2=5:10:0.5
// Sweep cost ratio: prism model.nm props.pctl -const CS=1:10:1
